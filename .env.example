# Firstory 登入設定
FIRSTORY_EMAIL=your-email@example.com
FIRSTORY_PASSWORD=your-password

# Airtable 設定
AIRTABLE_API_KEY=pat1.xxxxxxxxxx
AIRTABLE_BASE_ID=app19Zwdzq4sWcREm
AIRTABLE_TABLE_NAME=Daily Podcast Summary

GOOGLE_CLIENT_ID=你的Client_ID
GOOGLE_CLIENT_SECRET=你的Client_Secret

# Google Gemini API 設定（已被 OpenRouter 取代）
# GEMINI_API_KEY=your-gemini-api-key

# OpenRouter API 設定
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_SITE_URL=https://your-site-url.com
OPENROUTER_SITE_NAME=AI Podcast Automation

# Google Drive 設定 (使用服務帳戶 JSON 檔案)
GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json

# 上傳排程設定 (Cron 格式, 預設每天上午 9 點)
UPLOAD_SCHEDULE=0 9 * * *

# 測試模式設定
PLAYWRIGHT_HEADLESS=false
DEBUG_MODE=true

# ─────────────────────────────────────────────────────────────
# Shorts pipeline (40–60s podcast highlight videos)
# All optional — each stage falls back to a stub if its key is missing.
# See src/services/shortsPipeline/README.md
# ─────────────────────────────────────────────────────────────

# OpenAI Whisper for transcription
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# VoAI 絕好聲創 — Taiwan-accent TTS
VOAI_API_KEY=
VOAI_VOICE_ID=
VOAI_API_BASE=https://api.voai.ai/v1

# Hedra Character-3 — animate sloth image lip-synced to VoAI audio
HEDRA_API_KEY=
HEDRA_API_BASE=https://api.hedra.com/web-app/public

# Pexels — free stock B-roll
PEXELS_API_KEY=

# kie.ai — Veo 3 Fast hero B-roll clip + nano-banana-edit cover cleanup
KIE_AI_API_KEY=
# Generate a bespoke 8s Veo 3 Fast hero clip for the first B-roll slot (~$0.30/clip)
ENABLE_KIE_HERO_BROLL=false
# Run the uploaded IG cover through nano-banana-edit to erase baked-in text
# and outpaint to 9:16 before feeding it to Hedra (~$0.02/image)
ENABLE_KIE_IMAGE_EDIT=false

# Cloudinary — temp image hosting for kie.ai uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=